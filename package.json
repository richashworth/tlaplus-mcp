{
  "name": "@richashworth/tlaplus-mcp",
  "version": "0.1.3",
  "description": "MCP server for TLA+ toolchain (TLC, SANY, PlusCal, TLATeX)",
  "license": "MIT",
  "author": "Richard Ashworth",
  "repository": {
    "type": "git",
    "url": "https://github.com/richashworth/tlaplus-mcp.git"
  },
  "homepage": "https://github.com/richashworth/tlaplus-mcp",
  "bugs": {
    "url": "https://github.com/richashworth/tlaplus-mcp/issues"
  },
  "keywords": [
    "tla+",
    "tlaplus",
    "mcp",
    "model-checking",
    "tlc",
    "formal-verification",
    "pluscal",
    "model-context-protocol"
  ],
  "type": "module",
  "bin": {
    "tlaplus-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
